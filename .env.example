DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/supplai
# Single-key setup. For rotation across multiple keys (free-tier quota
# failover), set GEMINI_API_KEYS instead as a comma-separated list.
GEMINI_API_KEY=
# GEMINI_API_KEYS=key-A,key-B,key-C
TAVILY_API_KEY=
DEMO_OFFLINE_CACHE=false
